{
  "name": "chess-scan-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare-stockfish": "node scripts/copy-stockfish.mjs",
    "predev": "npm run prepare-stockfish",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run prepare-stockfish",
    "build": "tsc -b && vite build",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "typecheck": "tsc -b --pretty false",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "chess.js": "1.4.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stockfish": "18.0.8",
    "typescript": "7.0.2",
    "vite": "8.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
